# === Class Models — nieuw platform (kopieer naar .env in root of per app) ===
# Zie docs/ voor uitleg per variabele.

# Database (MySQL — lokaal: docker compose up -d mysql, poort 3307)
# Prisma leest DB_URL. Zet lokaal beide op dezelfde waarde (Prisma CLI laadt geen Nest env.bootstrap).
DATABASE_URL="mysql://cmuser:cmpass@127.0.0.1:3307/classmodels"
DB_URL="mysql://cmuser:cmpass@127.0.0.1:3307/classmodels"

# API
API_PORT=4000
API_HOST=0.0.0.0

# E-mail (agenda bevestiging) — zonder SMTP_HOST wordt alleen gelogd
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Class Models <noreply@classmodels.be>"
# Optioneel: Google Static Maps voor routekaart in bevestigingsmail (betrouwbaarder dan OSM-hotlink)
# GOOGLE_MAPS_API_KEY=""

JWT_SECRET="change-me-min-32-chars-for-production-use-openssl-rand"
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:3000,http://127.0.0.1:3000"

# Gastenportaal — annuleer-/bevestiglinks in mail/SMS (volledige URL van de Next-site, zelfde host als productie)
# Zonder correcte waarde wijzen links naar localhost of een verkeerd domein.
WEB_PUBLIC_URL="http://localhost:3000"
# Optioneel: tijdelijk import-wachtwoord tot hash in DB klopt (bv. classmodels2026!) — alleen op server zetten
# LEGACY_IMPORT_PASSWORD=""
# Zelfde als NEXT_PUBLIC_BASE_PATH (reset-links in mail)
# APP_PUBLIC_BASE_PATH=""
# Productie: zet op 1 om cancelUrl niet in JSON te tonen (alleen via mail)
# AGENDA_HIDE_CANCEL_LINK="1"

# Publieke URL’s (testomgeving)
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Optioneel: aparte basis voor <img src> /media/public. Standaard: als NEXT_PUBLIC_API_URL een publiek
# https-adres is (productie), gebruikt de web-app die voor foto-URL’s — rechtstreeks naar de API.
# NEXT_PUBLIC_MEDIA_BASE_URL="https://api.class-models.be"

# Mollie (test eerst)
MOLLIE_API_KEY_TEST="test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
MOLLIE_API_KEY_LIVE=""
MOLLIE_WEBHOOK_SECRET="whsec_change_me"
# test | live (default: test buiten productie)
MOLLIE_MODE="test"
PREMIUM_PRICE_EUROS=48
# Duur premium na betaling (dagen); promo levenslang zet premiumUntil op null
PREMIUM_DURATION_DAYS=365
# Promo: €48 levenslang t.o.v. €99/jaar (optioneel; default = volgende zaterdag 12:00 Europe/Brussels)
PREMIUM_PROMO_END_ISO=
NEXT_PUBLIC_PREMIUM_PROMO_END=
PREMIUM_YEARLY_PRICE_EUROS=99

# Mollie webhook & return (publiek bereikbaar voor Mollie; lokaal: ngrok of test op server)
API_PUBLIC_URL="http://localhost:4000"
# Na betaling: volledige URL of default = WEB_APP_URL/portal/model?premium=return
PAYMENT_REDIRECT_URL=""
WEB_APP_URL="http://localhost:3000"
# Optioneel: directe API-URL voor grote ZIP-uploads (bv. https://api.class-models.be) — vermijdt timeout via www-proxy
# Grote ZIP (chunked): bij voorkeur rechtstreeks api-subdomein (build-time). Anders same-origin /__cm_api.
NEXT_PUBLIC_LARGE_UPLOAD_API_URL=
# ZIP_UPLOAD_CHUNK_BYTES=8388608
# API_UPLOAD_TIMEOUT_MS=21600000
# COMBELL_UPLOAD_TIMEOUT_MS=21600000

# Firebase / push (optioneel in dev)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
NEXT_PUBLIC_FIREBASE_VAPID_KEY=""

# Web Push (VAPID). Zonder env genereert de API bij start een paar in apps/api/data/vapid-keys.json (niet committen).
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# Optioneel, bv. mailto:beheer@class-models.be
VAPID_CONTACT_EMAIL="mailto:info@classmodels.be"
# Volledige URL van de Next-app (voor klik op pushmelding)
APP_PUBLIC_URL="http://localhost:3000"
# Zelfde als NEXT_PUBLIC_BASE_PATH als je basePath gebruikt
APP_PUBLIC_BASE_PATH=""

# Media opslag (API schrijft hierheen; DB bevat alleen bestandsnamen)
# Lokaal: relatief pad ok. Productie: absoluut pad BUITEN de release-map (Combell: typisch
# $HOME/www/cm-media/uploads). Start je met combell-dual-proxy, dan wordt MEDIA_ROOT automatisch gezet.
# Zet in apps/api/.env GEEN relatief MEDIA_ROOT=uploads — dat overschrijft de proxy en laat
# bestanden in de git-release belanden (verdwijnen na deploy).
# Optioneel als resolve-media-root de hosting-map niet vindt: CM_SITE_ROOT, CM_MEDIA_UPLOADS
MEDIA_ROOT="./apps/api/uploads"
# Productie met Cloudflare R2 (Combell env — niet lokaal zonder keys):
# MEDIA_BACKEND=r2
# R2_BUCKET=classmodels-media
# R2_ACCOUNT_ID=
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# Combell Node-container: persistente uploads onder /app/shared/uploads (niet /home/…/www — die map ziet Node niet).
# MEDIA_ROOT=/app/shared/uploads
# Combell Node: schrijf naar data-site (deelt 100 GB webhosting):
# CM_COMBELL_DATA_UPLOADS=/data/sites/web/class-modelsbe/www/cm-media/uploads
# Optioneel: eenmalig kopiëren van oude hosting-map als die wél in de container gemount is:
# MEDIA_SYNC_SOURCE=/pad/naar/bron
# Nooit MEDIA_ROOT=/www/cm-media/uploads of alleen /home/…/www/… op Combell Node-container.
# Publieke bestanden: GET {MEDIA_PUBLIC_URL}/public/{bestandsnaam}
MEDIA_PUBLIC_URL="http://localhost:4000/media"

# Feature flags
NODE_ENV=development

# --- Combell (één Node-app: www + api.subdomein) ---
# Zet deze in het Combell-panel (niet alleen lokaal). Zie scripts/combell-env-copylist.txt
# Combell Node (VERPLICHT op productie — exact cijfer 1, GEEN punt "."):
# COMBELL_HOST_ROUTER=1
# DB_URL=postgresql://... of mysql://... (zelfde als productiedatabase)
# JWT_SECRET=...
# CORS_ORIGIN=https://www.class-models.be
# API_PUBLIC_URL=https://api.class-models.be
# NEXT_PUBLIC_API_URL=https://api.class-models.be
# Modellenportaal — modeshow-downloads (medialib map fotomodeshow-klein)
# Modeshow downloads (modelportaal) — exacte bestandsnamen uit mediatheek, geen giswerk:
# MODEL_MODESHOW_FILM_FROM=2026-05-21T00:00:00+02:00
# MODEL_MODESHOW_PHOTOS_FOLDER=film-modeshow
# MODEL_MODESHOW_ZIP_NAME=Modeshow ok JPG klein .zip
# MODEL_MODESHOW_FILM_NAME=Modeshow 2026.mp4.zip
