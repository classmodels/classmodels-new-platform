{
  "name": "classmodels-new-platform",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run build -w @cm/shared && concurrently -n api,web -c blue,green \"npm run dev -w @cm/api\" \"npm run dev -w @cm/web\"",
    "dev:fresh": "npm run ports:free && npm run dev",
    "rundev": "npm run dev",
    "dev:web": "npm run build -w @cm/shared && npm run dev -w @cm/web",
    "ports:free": "bash scripts/free-dev-ports.sh",
    "build": "node scripts/ensure-next-for-combell.cjs && npm run build -w @cm/api && npm run build -w @cm/web && node scripts/combell-sync-media-uploads.cjs",
    "serve": "node scripts/combell-serve.cjs",
    "start": "node scripts/combell-start.cjs",
    "db:generate": "npm run prisma:generate -w @cm/api",
    "db:migrate": "bash scripts/with-root-env.sh npm run prisma:migrate -w @cm/api",
    "db:deploy": "bash scripts/with-root-env.sh npm run prisma:deploy -w @cm/api",
    "wp:migrate": "bash scripts/with-root-env.sh npm run migrate:wp -w @cm/api",
    "wp:import-models": "bash scripts/wp-import-models.sh",
    "wp:import-model-photos": "bash scripts/wp-import-model-photos.sh",
    "tool:set-password": "bash scripts/tool-set-user-password.sh",
    "tool:import-profile-photos": "bash scripts/tool-import-profile-photos-manifest.sh",
    "db:seed": "bash scripts/with-root-env.sh npm run prisma:seed -w @cm/api",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "next": "^15.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
