{
  "name": "classmodels-new-platform",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run build -w @cm/shared && concurrently -n api,web -c blue,green \"npm run dev -w @cm/api\" \"npm run dev -w @cm/web\"",
    "build": "npm run build -w @cm/shared && npm run build -w @cm/api && npm run build -w @cm/web",
    "db:generate": "npm run prisma:generate -w @cm/api",
    "db:migrate": "bash scripts/with-root-env.sh npm run prisma:migrate -w @cm/api",
    "db:deploy": "bash scripts/with-root-env.sh npm run prisma:deploy -w @cm/api",
    "wp:migrate": "bash scripts/with-root-env.sh npm run migrate:wp -w @cm/api",
    "db:seed": "bash scripts/with-root-env.sh npm run prisma:seed -w @cm/api",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
