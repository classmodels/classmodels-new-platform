// Class Models — nieuw platform (PostgreSQL)
// Uitbreidbaar; migraties: npm run db:migrate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Portal {
  guest
  model
  client
}

enum UserStatus {
  active
  suspended
  pending
}

enum BriefStatus {
  open
  closed
  archived
}

enum BriefResponseStatus {
  submitted
  withdrawn
  accepted
  declined
}

model Role {
  id          String   @id @default(uuid())
  slug        String   @unique
  label       String
  description String?
  permissions Json     @default("[]")
  users       UserRole[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  passwordHash    String
  firstName       String?
  lastName        String?
  phone           String?
  bio             String?    @db.Text
  companyName     String?
  status          UserStatus @default(active)
  defaultPortal   Portal?
  isPremium       Boolean    @default(false)
  premiumUntil    DateTime?
  premiumOverride Boolean    @default(false)
  mollieCustomerId String?
  /// WordPress user id (import / foto-import)
  legacyWpUserId  Int?       @unique
  /// Hoofdportret voor modellenrooster (MediaAsset in map `models`)
  profilePhotoAssetId String? @unique
  profilePhoto    MediaAsset? @relation("UserProfilePhoto", fields: [profilePhotoAssetId], references: [id], onDelete: SetNull)
  roles           UserRole[]
  contentEdits    ContentString[]
  mediaAssets     MediaAsset[]
  auditLogs       AuditLog[]
  subscriptions   Subscription[]
  clientBriefs    ClientBrief[]       @relation("ClientBriefs")
  briefResponses  ModelBriefResponse[]
  agendaBookings  AgendaBooking[]
  /// WordPress-achtige modellenfiche (velden uit registratie-modellen-2 / cm_* meta)
  modelSheet      Json?
  favoritesGiven   ModelAdminFavorite[] @relation("AdminModelFav")
  favoritesReceived ModelAdminFavorite[] @relation("ModelFavoritedBy")
  /// Laatste succesvolle login (wachtwoord) — getoond in modellenportaal Historiek.
  lastLoginAt     DateTime?
  webPushSubscriptions WebPushSubscription[]
  modelPushSettings    ModelPushSettings?
  modelPushInbox       ModelPushInbox[]
  pushRecipientListsCreated PushRecipientList[] @relation("PushListCreatedBy")
  pushRecipientListMembers  PushRecipientListMember[]
  pushCampaignsAuthored     PushCampaign[]       @relation("PushCampaignAuthor")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model ClientBrief {
  id        String      @id @default(uuid())
  clientId  String
  client    User        @relation("ClientBriefs", fields: [clientId], references: [id], onDelete: Cascade)
  title     String
  /// Omschrijving (WP: omschrijving)
  body      String      @db.Text
  /// Extra info-blok (WP: extra_info)
  extraInfo String?     @db.Text
  /// Opdrachtdatum / start (WP: datum + begin_uur)
  eventDate DateTime?
  startTime String?
  endTime   String?
  wantedMen       Int?
  wantedWomen     Int?
  wantedChildren  Int?
  ageManFrom      Int?
  ageManTo        Int?
  ageWomanFrom    Int?
  ageWomanTo      Int?
  ageChildFrom    Int?
  ageChildTo      Int?
  status    BriefStatus @default(open)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  responses ModelBriefResponse[]
}

model ModelBriefResponse {
  id          String              @id @default(uuid())
  briefId     String
  brief       ClientBrief         @relation(fields: [briefId], references: [id], onDelete: Cascade)
  modelUserId String
  model       User                @relation(fields: [modelUserId], references: [id], onDelete: Cascade)
  message     String              @db.Text
  status      BriefResponseStatus @default(submitted)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([briefId, modelUserId])
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

/// Inline bewerkbare teksten (key = stabiele sleutel per scherm/blok)
model ContentString {
  id        String   @id @default(uuid())
  key       String   @unique
  locale    String   @default("nl")
  value     String   @db.Text
  portal    Portal?
  updatedById String?
  updatedBy User?    @relation(fields: [updatedById], references: [id])
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Menu {
  id        String     @id @default(uuid())
  slug      String     @unique
  label     String
  portal    Portal
  placement String     // left | top | middle | hidden
  items     MenuItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model MenuItem {
  id        String   @id @default(uuid())
  menuId    String
  menu      Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  label     String
  href      String
  sortOrder Int      @default(0)
  visibleWeb Boolean @default(true)
  visibleApp Boolean @default(true)
  requiresPremium Boolean @default(false)
  roleSlugs Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MediaFolder {
  id        String        @id @default(uuid())
  slug      String        @unique
  label     String
  /// Map-instellingen: deleteDaysAfterModelDownload, storeUploadsAsWebpOnly, …
  settings  Json          @default("{}")
  parentId  String?
  parent    MediaFolder?  @relation("FolderTree", fields: [parentId], references: [id])
  children  MediaFolder[] @relation("FolderTree")
  assets    MediaAsset[]
  createdAt DateTime      @default(now())
}

model MediaAsset {
  id           String       @id @default(uuid())
  folderId     String?
  folder       MediaFolder? @relation(fields: [folderId], references: [id])
  originalName String
  storageKey   String       @unique
  mimeType     String
  sizeBytes    Int
  width        Int?
  height       Int?
  webpKey      String?
  thumbKey     String?
  /// Eerste keer dat het model een download bevestigde (map met auto-wis policy).
  modelDownloadedAt     DateTime?
  /// Na deze tijd wordt het bestand definitief gewist (cron/lightweight sweep).
  scheduledHardDeleteAt   DateTime?
  hardDeleted  Boolean      @default(false)
  uploadedById String?
  uploadedBy   User?        @relation(fields: [uploadedById], references: [id])
  profilePhotoFor User?     @relation("UserProfilePhoto")
  createdAt    DateTime     @default(now())
  testshootPhotos TestshootPhoto[]
}

/// Admin markeert favoriet-model (zoals WP `favs` usermeta).
model ModelAdminFavorite {
  id          String   @id @default(uuid())
  adminUserId String
  modelUserId String
  admin       User     @relation("AdminModelFav", fields: [adminUserId], references: [id], onDelete: Cascade)
  model       User     @relation("ModelFavoritedBy", fields: [modelUserId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([adminUserId, modelUserId])
}

/// Testshoot-galerij per “slot” (zoals WP Code Snippet): backstage-foto’s + feedback vóór download.
model TestshootModel {
  id               String              @id @default(uuid())
  name             String              @default("Model")
  sortOrder        Int                 @default(0)
  archived         Boolean             @default(false)
  /// Na eerste geslaagde feedback+download: volgende bezoekers mogen direct zip (zoals WP option).
  downloadUnlocked Boolean             @default(false)
  unlockedAt       DateTime?
  photos           TestshootPhoto[]
  feedbacks        TestshootFeedback[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model TestshootPhoto {
  id        String         @id @default(uuid())
  modelId   String
  model     TestshootModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  assetId   String
  asset     MediaAsset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())

  @@unique([modelId, assetId])
}

model TestshootFeedback {
  id        String         @id @default(uuid())
  modelId   String
  model     TestshootModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  payload   Json
  ip        String?
  createdAt DateTime       @default(now())
}

model Review {
  id          String   @id @default(uuid())
  title       String
  body        String   @db.Text
  authorName  String?
  rating      Int?
  sortOrder   Int      @default(0)
  approved    Boolean  @default(false)
  visible     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PushCampaign {
  id          String    @id @default(uuid())
  title       String
  body        String    @db.Text
  audience    Json
  scheduledFor DateTime?
  sentAt      DateTime?
  /// Backoffice-gebruiker die verstuurde (optioneel).
  sentByUserId String?
  sentBy       User?    @relation("PushCampaignAuthor", fields: [sentByUserId], references: [id], onDelete: SetNull)
  /// Doellijst (als `audience.kind` = `custom_list`).
  recipientListId String?
  recipientList   PushRecipientList? @relation(fields: [recipientListId], references: [id], onDelete: SetNull)
  deliveries ModelPushInbox[]
  createdAt   DateTime  @default(now())
}

/// Web Push (VAPID) — één browser/app per endpoint.
model WebPushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

/// Model: push bij historiek + push bij bureau-broadcasts (onafhankelijk aan/uit).
model ModelPushSettings {
  userId                 String   @id
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Push + inbox bij gebeurtenissen die ook in Historiek verschijnen.
  notifyHistoryEvents    Boolean  @default(true)
  /// Push + inbox bij berichten vanuit de backsite.
  notifyAgencyBroadcasts Boolean  @default(true)
  updatedAt              DateTime @updatedAt
}

/// Inbox in het modellenportaal (tab Pushberichten).
model ModelPushInbox {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  body       String   @db.Text
  /// `history` | `agency`
  source     String
  meta       Json?
  readAt     DateTime?
  campaignId String?
  campaign   PushCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([userId, readAt, createdAt])
}

/// Door beheerder beheerde lijsten voor gerichte push.
model PushRecipientList {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  createdById String?
  createdBy   User?    @relation("PushListCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  members     PushRecipientListMember[]
  campaigns   PushCampaign[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PushRecipientListMember {
  listId    String
  list      PushRecipientList @relation(fields: [listId], references: [id], onDelete: Cascade)
  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([listId, userId])
}

model MollieSettings {
  id           Int      @id @default(1)
  apiKeyTest   String?
  apiKeyLive   String?
  webhookUrl   String?
  premiumPrice Decimal  @default(48) @db.Decimal(10, 2)
  updatedAt    DateTime @updatedAt
}

model Subscription {
  id                   String   @id @default(uuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  molliePaymentId      String?  @unique
  mollieSubscriptionId String?
  status               String
  amount               Decimal  @db.Decimal(10, 2)
  currency             String   @default("EUR")
  isRecurring          Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

/// Extensies / snippets (metadata; uitvoering later sandboxed)
model PluginSnippet {
  id          String   @id @default(uuid())
  slug        String   @unique
  version     String
  enabled     Boolean  @default(false)
  manifest    Json
  bundlePath  String
  createdAt   DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  meta      Json?
  createdAt DateTime @default(now())
}

model MigrationBatch {
  id        String   @id @default(uuid())
  source    String   @default("wordpress")
  status    String
  report    Json?
  createdAt DateTime @default(now())
}

// --- Agenda (Class Models Agenda Pro — equivalent in PostgreSQL) ---

model AgendaCalendar {
  id              String           @id @default(uuid())
  slug            String           @unique
  title           String
  description     String?          @db.Text
  color           String           @default("#6f121b")
  durationMinutes Int              @default(30)
  capacity        Int              @default(1)
  active          Boolean          @default(true)
  publicBooking   Boolean          @default(true)
  /// Alleen dagen in AgendaOpenDay tonen (Agenda Pro: oranje = geopend voor publiek).
  restrictToOpenDays Boolean       @default(false)
  /// Standaardvenster voor automatische sloten bij open dagen (HH:mm:ss).
  defaultDayStartTime String       @default("08:00:00")
  defaultDayEndTime   String         @default("18:00:00")
  /// Pauze (optioneel): geen sloten die dit interval kruisen.
  breakStart          String?
  breakEnd            String?
  sortOrder       Int              @default(100)
  slots           AgendaSlot[]
  fields          AgendaField[]
  bookings        AgendaBooking[]
  closedDays      AgendaClosedDay[]
  openDays        AgendaOpenDay[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model AgendaOpenDay {
  id           String         @id @default(uuid())
  calendarId   String
  calendar     AgendaCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  openDate     DateTime       @db.Date
  repeatYearly Boolean        @default(false)
  createdAt    DateTime       @default(now())

  @@unique([calendarId, openDate])
  @@index([calendarId, openDate])
}

model AgendaSlot {
  id         String           @id @default(uuid())
  calendarId String
  calendar   AgendaCalendar   @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  slotDate   DateTime         @db.Date
  startTime  String
  endTime    String
  capacity   Int              @default(1)
  status     String           @default("open")
  notes      String?          @db.Text
  bookings   AgendaBooking[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([calendarId, slotDate])
}

model AgendaField {
  id            String         @id @default(uuid())
  calendarId    String
  calendar      AgendaCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  fieldKey      String
  label         String
  type          String         @default("text")
  required      Boolean        @default(false)
  width         String         @default("2")
  placeholder   String?
  titlePosition String         @default("above")
  sortOrder     Int            @default(100)
  active        Boolean        @default(true)
  options       String?        @db.Text

  @@unique([calendarId, fieldKey])
  @@index([calendarId])
}

model AgendaClosedDay {
  id         String         @id @default(uuid())
  calendarId String
  calendar   AgendaCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  closedDate DateTime       @db.Date
  reason     String?
  createdAt  DateTime       @default(now())

  @@unique([calendarId, closedDate])
}

model AgendaBooking {
  id          String           @id @default(uuid())
  calendarId  String
  calendar    AgendaCalendar   @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  slotId      String
  slot        AgendaSlot       @relation(fields: [slotId], references: [id], onDelete: Restrict)
  userId      String?
  user        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  startAt     DateTime
  endAt       DateTime
  status      String           @default("confirmed")
  name        String?
  firstname   String?
  lastname    String?
  email       String?
  phone       String?
  fieldsJson  Json             @default("{}")
  source      String           @default("web")
  /// Uniek token voor annuleren via link in bevestigingsmail
  cancelToken String?          @unique
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([calendarId, startAt])
  @@index([slotId])
}
