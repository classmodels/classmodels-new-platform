# Kopieer naar `.env.production` in deze map (die staat in .gitignore).
# Gebruik alleen lokaal om het wachtwoord-batchscript tegen productie-DB te draaien.
#
#   cd apps/api
#   set -a && source .env.production && set +a
#   npx prisma generate
#   npm run tool:set-model-temp-password -- --dry-run --password='classmodels2026!'
