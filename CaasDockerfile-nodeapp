# Combell / Caas: dit bestand MOET uit de repo komen (niet Combell's standaard met apt upgrade).
# Controle in build-log: stap "RUN apt-get" installeert alleen git + ca-certificates (geen node-* lijst).
# Build command in paneel (aanbevolen): npm run combell:build  (zonder Docker/CaaS-container).
FROM node:22-bookworm-slim
WORKDIR /app

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update -qq \
  && apt-get install -y --no-install-recommends -qq git ca-certificates \
  && apt-get clean \
  && rm -rf /var/lib/apt/lists/*

COPY package.json package-lock.json .npmrc ./
COPY packages ./packages
COPY apps ./apps
COPY scripts ./scripts
COPY shared/README.md ./shared/README.md

# Zonder npm ci faalt combell:build in Docker (geen node_modules / Prisma client).
RUN npm ci
RUN npm run combell:build

ENV NODE_ENV=production
EXPOSE 3000
CMD ["npm", "run", "serve"]
